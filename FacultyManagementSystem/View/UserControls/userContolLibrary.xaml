<UserControl x:Class="FacultyManagementSystem.View.UserControls.userContolLibrary"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:FacultyManagementSystem.View.UserControls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="533">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Text="Library Management" FontSize="20" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="5"/>

        <Grid Grid.Row="1" Grid.ColumnSpan="2" HorizontalAlignment="Center">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Vertical" HorizontalAlignment="Left" Margin="0,0,100,0">
                <TextBlock Text="Book Title:"/>
                <TextBox Width="260" Margin="5" Text="{Binding BookTitle}"/>
                <TextBlock Text="Author:"/>
                <TextBox Margin="5" Text="{Binding Author}"/>
                <TextBlock Text="ISBN:"/>
                <TextBox Margin="5" Text="{Binding ISBN}"/>
                <TextBlock Text="Description:"/>
                <TextBox Margin="5" Text="{Binding Description}"/>
                <TextBlock Text="Barcode:"/>
                <TextBox Margin="5" Text="{Binding Barcode}"/>
                <TextBlock Text="Number of copies:"/>
                <TextBox Margin="5" Text="{Binding NumberOfCopies}" PreviewTextInput="TextBox_PreviewTextInput"/>

                <Button Content="Add Book" Width="100" Margin="10" Command="{Binding AddBookCommand}"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Vertical" HorizontalAlignment="Center" Margin="100,0,100,0">
                <TextBlock Text="Book barcode"/>
                <TextBox Text="{Binding ScannedBookBarcode}" Margin="5"/>
                <TextBlock Text="Member barcode"/>
                <TextBox Text="{Binding ScannedMemberBarcode}" Margin="5"/>
                <Button Content="Issue Book" Width="100" Margin="10" Command="{Binding IssueBookCommand}"/>
                <Button Content="Return Book" Width="100" Margin="10" Command="{Binding ReturnBookCommand}"/>
                <Button Content="Remove Book" Width="100" Margin="10" Command="{Binding RemoveBookCommand}"/>
            </StackPanel>

            <StackPanel Grid.Column="2" Orientation="Vertical" HorizontalAlignment="Right" Margin="100,0,0,0">
                <TextBlock Text="Search Books" FontSize="16" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="5"/>

                <TextBox Margin="5" Width="200" Text="{Binding SearchKeywords}"/>
                
                <Button Content="Search" Width="100" Margin="10" Command="{Binding SearchBookCommand}"/>
            </StackPanel>
        </Grid>

        <StackPanel Grid.Row="2" Grid.ColumnSpan="2">
            <TextBlock Text="Search results:" FontSize="16" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="5"/>
            <ListView Name="listViewSearchedBooks" Grid.RowSpan="2" Margin="10" Height="400">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="Title" DisplayMemberBinding="{Binding Title}" Width="150"/>
                        <GridViewColumn Header="Author" DisplayMemberBinding="{Binding Author}" Width="100"/>
                        <GridViewColumn Header="ISBN" DisplayMemberBinding="{Binding ISBN}" Width="100"/>
                        <GridViewColumn Header="Barcode" DisplayMemberBinding="{Binding Barcode}" Width="100"/>
                        <GridViewColumn Header="Copies" DisplayMemberBinding="{Binding NumberOfCopies}" Width="120"/>
                        <GridViewColumn Header="Available Copies" DisplayMemberBinding="{Binding NumberOfAvailableCopies}" Width="120"/>
                    </GridView>
                </ListView.View>
            </ListView>
        </StackPanel>




    </Grid>
</UserControl>
