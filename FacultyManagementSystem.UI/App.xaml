<Application x:Class="FacultyManagementSystem.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:FacultyManagementSystem"
             xmlns:viewModel="clr-namespace:FacultyManagementSystem.UI.ViewModel"
             xmlns:viewModelLibrary="clr-namespace:FacultyManagementSystem.UI.ViewModel.Library"
             xmlns:view="clr-namespace:FacultyManagementSystem.UI.View"
             xmlns:components="clr-namespace:FacultyManagementSystem.UI.View.Components">
    <Application.Resources>
        <DataTemplate DataType="{x:Type TypeName=viewModelLibrary:LibrarySearchBooksViewModel}">
            <components:LibrarySearchBooks/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type TypeName=viewModelLibrary:LibraryAddBookViewModel}">
            <components:LibraryAddBook/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type TypeName=viewModelLibrary:LibraryIssueBookViewModel}">
            <components:LibraryIssueBook/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type TypeName=viewModel:FacultyViewModel}">
            <view:FacultyView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type TypeName=viewModel:StudentViewModel}">
            <view:StudentView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type TypeName=viewModel:LoginViewModel}">
            <view:LoginView/>
        </DataTemplate>
    </Application.Resources>
</Application>
