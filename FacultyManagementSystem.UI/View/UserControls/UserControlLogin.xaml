<UserControl x:Class="FacultyManagementSystem.UI.View.UserControls.UserControlLogin"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:FacultyManagementSystem.UI.View.UserControls"
             mc:Ignorable="d" 
             Height="1080" Width="1536">
    <Grid>
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Width="400">
            <TextBlock Text="Login" FontSize="36" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,20"/>
            <TextBlock Text="Username:" FontSize="20" Margin="0,0,0,5"/>
            <TextBox FontSize="20" Margin="0,0,0,15"/>
            <TextBlock Text="Password:" FontSize="20" Margin="0,0,0,5"/>
            <PasswordBox FontSize="20" Margin="0,0,0,25" Con/>
        </StackPanel>
    </Grid>
</UserControl>
