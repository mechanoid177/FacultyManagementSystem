<UserControl x:Class="FacultyManagementSystem.View.UserControls.userContolLibrary"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:FacultyManagementSystem.View.UserControls"
             mc:Ignorable="d" Height="1080" Width="1536">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="2*"/>
        </Grid.ColumnDefinitions>

        <!-- Headline -->
        <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Text="Library Management System" FontSize="41" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="20,20,20,50"/>

        <StackPanel Grid.Row="1" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Center" Width="1536" Margin="0, 0, 0, 15">

            <!-- Add book -->
            <StackPanel Orientation="Vertical" HorizontalAlignment="Center" Width="500" Margin="20">
                <TextBlock Text="Book Title:"/>
                <TextBox FontSize="32" Margin="5" Text="{Binding BookTitle}"/>
                <TextBlock Text="Author:"/>
                <TextBox FontSize="32" Margin="5" Text="{Binding Author}"/>
                <TextBlock Text="ISBN:"/>
                <TextBox FontSize="32" Margin="5" Text="{Binding ISBN}"/>
                <TextBlock Text="Description:"/>
                <TextBox FontSize="32" Margin="5" Text="{Binding Description}"/>
                <TextBlock Text="Barcode:"/>
                <TextBox FontSize="32" Margin="5" Text="{Binding Barcode}"/>
                <TextBlock Text="Number of copies:"/>
                <TextBox FontSize="24" Margin="5" Text="{Binding NumberOfCopies}" PreviewTextInput="TextBox_PreviewTextInput"/>

                <Button Content="Add Book" FontSize="32" Width="150" Margin="10" HorizontalAlignment="Left" Command="{Binding AddBookCommand}"/>
            </StackPanel>

            <!-- Issue, return or remove book -->
            <StackPanel Orientation="Vertical" HorizontalAlignment="Right" Margin="160, 20, 20, 20">
                <StackPanel Orientation="Horizontal">
                    <StackPanel Orientation="Vertical">
                        <TextBlock Text="Book barcode"/>
                        <TextBox FontSize="32" HorizontalAlignment="Left" Text="{Binding ScannedBookBarcode}" Margin="5" Width="400"/>
                    </StackPanel>
                    <StackPanel Orientation="Vertical">
                        <TextBlock Text="Member barcode"/>
                        <TextBox FontSize="32" HorizontalAlignment="Right" Text="{Binding ScannedMemberBarcode}" Margin="5" Width="400"/>
                    </StackPanel>
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <Button Content="Issue Book" FontSize="32" Width="200" Margin="10" Command="{Binding IssueBookCommand}"/>
                    <Button Content="Return Book" FontSize="32" Width="200" Margin="10" Command="{Binding ReturnBookCommand}"/>
                    <Button Content="Remove Book" FontSize="32" Width="200" Margin="10" Command="{Binding RemoveBookCommand}"/>
                </StackPanel>
            </StackPanel>
        </StackPanel>



        <!-- Search results -->
        <StackPanel Grid.Row="2" Grid.ColumnSpan="2" Orientation="Vertical">

            <TextBlock Text="Search for books" FontSize="32" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="5"/>

            <!-- Search input -->
            <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Center">
                <TextBox FontSize="32" HorizontalAlignment="Left" Margin="5" Width="1252" Text="{Binding SearchKeywords}"/>
                <Button Content="Search" HorizontalAlignment="Right" FontSize="32" Width="150" Margin="10" Command="{Binding SearchBookCommand}"/>
            </StackPanel>

            <!-- Search output -->
            <ListView Name="listViewSearchedBooks" Grid.RowSpan="2" Margin="10" Height="250">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="Title" DisplayMemberBinding="{Binding Title}" Width="150"/>
                        <GridViewColumn Header="Author" DisplayMemberBinding="{Binding Author}" Width="100"/>
                        <GridViewColumn Header="ISBN" DisplayMemberBinding="{Binding ISBN}" Width="100"/>
                        <GridViewColumn Header="Barcode" DisplayMemberBinding="{Binding Barcode}" Width="100"/>
                        <GridViewColumn Header="Copies" DisplayMemberBinding="{Binding NumberOfCopies}" Width="120"/>
                        <GridViewColumn Header="Available Copies" DisplayMemberBinding="{Binding NumberOfAvailableCopies}" Width="120"/>
                    </GridView>
                </ListView.View>
            </ListView>
        </StackPanel>




    </Grid>
</UserControl>
