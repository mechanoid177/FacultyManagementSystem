<UserControl x:Class="FacultyManagementSystem.UI.View.Components.LibraryAddBook"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:FacultyManagementSystem.UI.View.Components"
             mc:Ignorable="d" >
    <Grid>
        <StackPanel Orientation="Vertical" HorizontalAlignment="Center" Width="500" Margin="20">
            <TextBlock Text="Book Title:"/>
            <TextBox FontSize="28" Margin="5" Text="{Binding BookTitle}"/>
            <TextBlock Text="Author:"/>
            <TextBox FontSize="28" Margin="5" Text="{Binding Author}"/>
            <TextBlock Text="ISBN:"/>
            <TextBox FontSize="28" Margin="5" Text="{Binding ISBN}"/>
            <TextBlock Text="Description:"/>
            <TextBox FontSize="28" Margin="5" Text="{Binding Description}"/>
            <TextBlock Text="Barcode:"/>
            <TextBox FontSize="28" Margin="5" Text="{Binding Barcode}"/>
            <TextBlock Text="Number of copies:"/>
            <TextBox FontSize="28" Margin="5" Text="{Binding NumberOfCopies}" PreviewTextInput="TextBox_PreviewTextInput"/>

            <Button Content="Add Book" FontSize="32" Width="490" Margin="10" Command="{Binding AddBookCommand}"/>
            <Button Content="Remove Book" FontSize="32" Width="490" Margin="10" Command="{Binding RemoveBookCommand}"/>
        </StackPanel>
    </Grid>
</UserControl>
