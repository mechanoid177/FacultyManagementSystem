<UserControl x:Class="FacultyManagementSystem.UI.View.Components.LibraryIssueBook"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:FacultyManagementSystem.UI.View.Components"
             mc:Ignorable="d" >
    <Grid>
        <StackPanel Orientation="Vertical" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0">
            <StackPanel Orientation="Vertical">
                <StackPanel Orientation="Vertical">
                    <TextBlock Text="Book barcode"/>
                    <TextBox FontSize="28" HorizontalAlignment="Center" Text="{Binding ScannedBookBarcode}" Margin="5" Width="400"/>
                </StackPanel>
                <StackPanel Orientation="Vertical">
                    <TextBlock Text="Member barcode"/>
                    <TextBox FontSize="28" HorizontalAlignment="Center" Text="{Binding ScannedMemberBarcode}" Margin="5" Width="400"/>
                </StackPanel>
            </StackPanel>
            <StackPanel Orientation="Horizontal">
                <Button Content="Issue Book" FontSize="28" Width="200" Margin="10" Command="{Binding IssueBookCommand}"/>
                <Button Content="Return Book" FontSize="28" Width="200" Margin="10" Command="{Binding ReturnBookCommand}"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</UserControl>
